<%- include('../partials/header') %>
<section class="card">
  <h2>비밀번호 찾기/초기화</h2>
  <% if (error) { %><p class="error"><%= error %></p><% } %>
  <% if (success) { %><p class="success"><%= success %></p><% } %>
  <% if (guide) { %><p class="notice"><%= guide %></p><% } %>

  <form method="post" action="/auth/reset-password/request">
    <label>이메일 또는 전화번호<input name="identifier" required /></label>
    <button type="submit">인증코드 요청</button>
  </form>

  <form method="post" action="/auth/reset-password/confirm">
    <label>인증코드<input name="code" required /></label>
    <label>새 비밀번호(8자 이상)<input type="password" name="newPassword" minlength="8" required /></label>
    <button type="submit">비밀번호 초기화</button>
  </form>
</section>
<%- include('../partials/footer') %>
